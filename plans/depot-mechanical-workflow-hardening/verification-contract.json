{
  "schema_version": 1,
  "contract_id": "depot-mechanical-workflow-hardening",
  "revision": 1,
  "previous_contract_digest": null,
  "requirements": [
    {"id":"REQ-01","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-1","statement":"Preserve current work, use the approved isolated branch stacked on PR 12, and deliver without merging, publishing releases, or refreshing caches."},
    {"id":"REQ-02","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-2","statement":"Add a deterministic project-configurable verification planner using safe argv arrays, repository profiles, structured results, and no generic hardcoded application paths."},
    {"id":"REQ-03","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-3","statement":"Encode a tiered verification ladder preserving race, security, browser, accessibility, remote, and post-merge authority while selecting local work by risk and changed scope."},
    {"id":"REQ-04","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-4","statement":"Make dm-review and review strictly read-only, with mutation reserved for explicitly approved dm-review-fix and dm-review-loop flows."},
    {"id":"REQ-05","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-5","statement":"Bind reviews and verification to exact Git, build, and profile state and invalidate stale evidence after relevant state changes."},
    {"id":"REQ-06","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-6","statement":"Persist versioned structured reviewer findings incrementally while preserving partial results, provenance, coverage gaps, provider routing, and stable identity."},
    {"id":"REQ-07","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-7","statement":"Extend the existing browser verification and recovery model into executable scenarios and one immutable evidence bundle shared by independent reviewers."},
    {"id":"REQ-08","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-8","statement":"Classify artifacts by sensitivity and lifecycle, redact private evidence safely, and generate exact staging allowlists instead of broad staging."},
    {"id":"REQ-09","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-9","statement":"Normalize provider-neutral CI evidence while preserving distinctions among PR, push, scheduled, skipped, and post-merge authority."},
    {"id":"REQ-10","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-10","statement":"Add deterministic PR and issue closeout auditing for exact heads, state, evidence, references, issue state, claimed scope, and closing dispositions."},
    {"id":"REQ-11","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-11","statement":"Keep neutral mechanics in Workflow Kernel, Assembly defaults in Assembly, and Pipeline and dm-review as consumers, using shadow parity before enforcement and preserving agent judgment."},
    {"id":"REQ-12","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-12","statement":"Add hostile-input, schema, CLI, contract, generator-parity, and integration tests and run Depot canonical validators."},
    {"id":"REQ-13","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-13","statement":"Measure only available evidence for lanes, setup, ownership, durations, waits, and manual steps without inventing savings."},
    {"id":"REQ-14","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-14","statement":"Produce an evidence-backed final crosscheck and exact fresh independent dm-review prompt while leaving delivery unmerged and draft."},
    {"id":"REQ-15","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#key-requirements-extracted-15","statement":"Add an every-run proposal-only Upstream Improvement Scout with structured candidates, a reusable Pipeline prompt, and a valid empty result."}
  ],
  "prohibited_regressions": [
    {"id":"REG-01","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#supplied-pipeline-prompt","statement":"Do not weaken race, security, browser, accessibility, issue-reconciliation, final-review, exact-owned cleanup, or no-merge gates."},
    {"id":"REG-02","source_ref":"AGENTS.md#editing-rules","statement":"Keep Claude plugin manifests and commands canonical and regenerate Codex manifests and command-skill aliases."},
    {"id":"REG-03","source_ref":"plans/depot-mechanical-workflow-hardening/original-prompt.md#delivery","statement":"Do not publish releases, refresh installed caches, merge the feature branch, or mutate PR and issue state during read-only review."}
