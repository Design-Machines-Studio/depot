{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/workflow-kernel/cleanup-plan-v1.json",
  "title": "Workflow kernel proof-bound cleanup plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "before", "actions"],
  "properties": {
    "schema_version": {"const": 1},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "terminal", "stale_sweep"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "node_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "terminal": {"type": "boolean"},
        "stale_sweep": {"type": "boolean"}
      }
    },
    "before": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}, "uniqueItems": true},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_id", "kind", "action", "argv", "requires_success_of", "owner", "lifecycle", "proof_digest", "preconditions"],
        "properties": {
          "resource_id": {"type": "string", "minLength": 1, "maxLength": 4096},
          "kind": {"enum": ["worktree", "branch", "container", "network", "volume"]},
          "action": {"enum": ["stop", "remove"]},
          "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
          "requires_success_of": {"type": ["integer", "null"], "minimum": 0},
          "owner": {
            "type": "object", "additionalProperties": false,
            "required": ["run_id", "node_id"],
            "properties": {
              "run_id": {"type": "string", "minLength": 1, "maxLength": 256},
              "node_id": {"type": "string", "minLength": 1, "maxLength": 256}
            }
          },
          "lifecycle": {"enum": ["chunk", "run"]},
          "proof_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "preconditions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 4096}}
        }
      }
    }
  }
}
