{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/browser-scenario-schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scenario_id", "case_id", "profile_id", "persona_id", "target_origin_digest", "initial_route", "primary_engine", "alternate_engine", "viewport", "steps", "scenario_digest"],
  "properties": {
    "schema_version": {"const": 1},
    "scenario_id": {"$ref": "#/$defs/id"},
    "case_id": {"type": "string", "pattern": "^case-sha256:[0-9a-f]{64}$"},
    "profile_id": {"type": "string", "pattern": "^profile-sha256:[0-9a-f]{64}$"},
    "persona_id": {"$ref": "#/$defs/id"},
    "target_origin_digest": {"type": "string", "pattern": "^origin-sha256:[0-9a-f]{64}$"},
    "initial_route": {"$ref": "#/$defs/route"},
    "primary_engine": {"$ref": "#/$defs/engine"},
    "alternate_engine": {"oneOf": [{"$ref": "#/$defs/engine"}, {"type": "null"}]},
    "viewport": {"$ref": "#/$defs/viewport"},
    "steps": {"type": "array", "minItems": 1, "maxItems": 512, "items": {"$ref": "#/$defs/step"}},
    "scenario_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._:-]*$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "engine": {"enum": ["chromium", "firefox", "webkit"]},
    "viewport": {"type": "string", "pattern": "^(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])x(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])$"},
    "route": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^/(?!/)(?!.*[?#\\\\]).*$"},
    "safe": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\u0000-\\u001f\\u007f]+$"},
    "nullable_safe": {"oneOf": [{"$ref": "#/$defs/safe"}, {"type": "null"}]},
    "payload": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "route": {"$ref": "#/$defs/route"},
        "locator_kind": {"enum": ["selector", "role", "label", "none"]},
        "locator": {"$ref": "#/$defs/nullable_safe"},
        "action": {"enum": ["click", "fill", "check", "uncheck", "select", "press", "mfa", "passkey", "qr_scan", "external_sign_in"]},
        "value_ref": {"$ref": "#/$defs/nullable_safe"},
        "profile_ref": {"$ref": "#/$defs/safe"}, "cookie_jar_ref": {"$ref": "#/$defs/nullable_safe"},
        "environment_fixture_refs": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"$ref": "#/$defs/safe"}},
        "login_fixture_ref": {"$ref": "#/$defs/nullable_safe"},
        "lifecycle": {"enum": ["success", "expected_rejection", "human_action_required", "auth_verification"]},
        "fixture_ref": {"$ref": "#/$defs/nullable_safe"}, "enabled": {"type": "boolean"},
        "assertion": {"enum": ["url", "status", "visibility", "text", "count", "focus", "toast", "validation", "a11y", "console", "network", "computed_style", "overflow"]},
        "expected": {"type": ["string", "integer", "boolean", "null"]},
        "capture_kind": {"enum": ["screenshot", "trace", "console", "network", "a11y"]}, "artifact_ref": {"$ref": "#/$defs/safe"},
        "pause_id": {"$ref": "#/$defs/id"}, "session_expectation": {"enum": ["preserved", "cleared", "refreshed"]},
        "fresh_profile": {"const": true}, "expectation": {"enum": ["new", "preserved", "cleared", "authenticated", "anonymous"]},
        "attempt": {"type": "integer", "minimum": 2, "maximum": 3}, "engine": {"$ref": "#/$defs/engine"},
        "status": {"enum": ["passed", "human_action_required", "human_help_required", "application_failure"]},
        "reason": {"enum": ["first_pass", "fresh_primary", "alternate_engine", "human_action_required", "human_help_required", "application_failure"]}
      }
    },
    "step": {
      "type": "object", "additionalProperties": false, "required": ["step_id", "kind", "payload"],
      "properties": {
        "step_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["navigate", "interact", "state_fixture", "login", "javascript", "assertion", "capture", "human_pause", "application_restart", "primary_quit", "primary_launch", "session_assertion", "primary_retry", "alternate_engine", "terminal"]},
        "payload": {"$ref": "#/$defs/payload"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "navigate"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["route"], "properties": {"route": {"$ref": "#/$defs/route"}}}}}},
        {"if": {"properties": {"kind": {"const": "interact"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["locator_kind", "locator", "action", "value_ref"], "properties": {"locator_kind": {"enum": ["selector", "role", "label"]}, "locator": {"$ref": "#/$defs/safe"}, "action": {"enum": ["click", "fill", "check", "uncheck", "select", "press"]}, "value_ref": {"$ref": "#/$defs/nullable_safe"}}}}}},
        {"if": {"properties": {"kind": {"const": "state_fixture"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["profile_ref", "cookie_jar_ref", "environment_fixture_refs", "login_fixture_ref"], "properties": {"profile_ref": {"$ref": "#/$defs/safe"}, "cookie_jar_ref": {"$ref": "#/$defs/nullable_safe"}, "environment_fixture_refs": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"$ref": "#/$defs/safe"}}, "login_fixture_ref": {"$ref": "#/$defs/nullable_safe"}}}}}},
        {"if": {"properties": {"kind": {"const": "login"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["lifecycle", "fixture_ref"], "properties": {"lifecycle": {"enum": ["success", "expected_rejection", "human_action_required", "auth_verification"]}, "fixture_ref": {"$ref": "#/$defs/nullable_safe"}}}}}},
        {"if": {"properties": {"kind": {"const": "javascript"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["enabled"], "properties": {"enabled": {"type": "boolean"}}}}}},
        {"if": {"properties": {"kind": {"const": "assertion"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["assertion", "locator_kind", "locator", "expected"], "properties": {"assertion": {"enum": ["url", "status", "visibility", "text", "count", "focus", "toast", "validation", "a11y", "console", "network", "computed_style", "overflow"]}, "locator_kind": {"enum": ["selector", "role", "label", "none"]}, "locator": {"$ref": "#/$defs/nullable_safe"}, "expected": {"type": ["string", "integer", "boolean", "null"]}}}}}},
        {"if": {"properties": {"kind": {"const": "capture"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["capture_kind", "artifact_ref"], "properties": {"capture_kind": {"enum": ["screenshot", "trace", "console", "network", "a11y"]}, "artifact_ref": {"$ref": "#/$defs/safe"}}}}}},
        {"if": {"properties": {"kind": {"const": "human_pause"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["pause_id", "action"], "properties": {"pause_id": {"$ref": "#/$defs/id"}, "action": {"enum": ["mfa", "passkey", "qr_scan", "external_sign_in"]}}}}}},
        {"if": {"properties": {"kind": {"const": "application_restart"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["session_expectation"], "properties": {"session_expectation": {"enum": ["preserved", "cleared", "refreshed"]}}}}}},
        {"if": {"properties": {"kind": {"const": "primary_quit"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "properties": {}}}}},
        {"if": {"properties": {"kind": {"const": "primary_launch"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["fresh_profile"], "properties": {"fresh_profile": {"const": true}}}}}},
        {"if": {"properties": {"kind": {"const": "session_assertion"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["expectation"], "properties": {"expectation": {"enum": ["new", "preserved", "cleared", "authenticated", "anonymous"]}}}}}},
        {"if": {"properties": {"kind": {"const": "primary_retry"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["attempt"], "properties": {"attempt": {"type": "integer", "minimum": 2, "maximum": 3}}}}}},
        {"if": {"properties": {"kind": {"const": "alternate_engine"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["engine"], "properties": {"engine": {"$ref": "#/$defs/engine"}}}}}},
        {"if": {"properties": {"kind": {"const": "terminal"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["status", "reason"], "properties": {"status": {"enum": ["passed", "human_action_required", "human_help_required", "application_failure"]}, "reason": {"enum": ["first_pass", "fresh_primary", "alternate_engine", "human_action_required", "human_help_required", "application_failure"]}}}}}}
      ]
    }
  }
}
