{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/workflow-policy-schema.json",
  "title": "Workflow Kernel Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "retry", "gates", "isolation", "capability_names", "workflow_safety_anchor", "economics", "verification"],
  "properties": {
    "schema_version": {"const": 1},
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budgets", "identical_signature_limit"],
      "properties": {
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider_unavailable", "deterministic_validation_failure", "reviewer_finding", "browser_recovery", "cleanup", "infrastructure"],
          "properties": {
            "provider_unavailable": {"type": "integer", "minimum": 0},
            "deterministic_validation_failure": {"type": "integer", "minimum": 0},
            "reviewer_finding": {"type": "integer", "minimum": 0},
            "browser_recovery": {"type": "integer", "minimum": 0},
            "cleanup": {"type": "integer", "minimum": 0},
            "infrastructure": {"type": "integer", "minimum": 0}
          }
        },
        "identical_signature_limit": {"type": "integer", "minimum": 2}
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_human_approval"],
      "properties": {
        "risk_human_approval": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["low", "medium", "high", "critical"]}
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "forbidden_downgrades"],
      "properties": {
        "order": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"enum": ["remote_sandbox", "container", "worktree", "sequential_branch"]}
        },
        "forbidden_downgrades": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {"enum": ["remote_sandbox", "container", "worktree", "sequential_branch"]},
              "to": {"enum": ["remote_sandbox", "container", "worktree", "sequential_branch"]}
            }
          }
        }
      }
    },
    "capability_names": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "uniqueItems": true,
      "items": {"enum": ["native_dispatch", "companion_dispatch", "wrapper_dispatch", "openrouter_exec", "session_resume", "remote_sandbox", "container", "worktree", "sequential_branch", "claude_execution", "codex_execution", "openrouter_execution", "anthropic_native_execution"]}
    },
    "workflow_safety_anchor": {"$ref": "#/$defs/workflow_safety_anchor"},
    "economics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {"mode": {"const": "proposal_only"}}
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["browser_engines", "desktop_viewport", "mobile_viewport"],
      "properties": {
        "browser_engines": {"const": ["chromium", "firefox"]},
        "desktop_viewport": {"type": "string", "pattern": "^[1-9][0-9]{1,4}x[1-9][0-9]{1,4}$"},
        "mobile_viewport": {"type": "string", "pattern": "^[1-9][0-9]{1,4}x[1-9][0-9]{1,4}$"}
      }
    }
  },
  "$defs": {
    "executor_constraint": {
      "allOf": [
        {"if": {"required": ["executor"], "properties": {"executor": {"const": null}}}, "then": {"properties": {"required_capability": {"const": null}, "required_dispatch_capability": {"const": null}}}},
        {"if": {"required": ["executor"], "properties": {"executor": {"const": "codex"}}}, "then": {"properties": {"required_capability": {"const": "codex_execution"}, "required_dispatch_capability": {"enum": [null, "native_dispatch", "companion_dispatch", "openrouter_exec"]}}}},
        {"if": {"required": ["executor"], "properties": {"executor": {"const": "openrouter"}}}, "then": {"properties": {"required_capability": {"const": "openrouter_execution"}, "required_dispatch_capability": {"enum": [null, "openrouter_exec"]}}}},
        {"if": {"required": ["executor"], "properties": {"executor": {"const": "claude"}}}, "then": {"properties": {"required_capability": {"enum": ["claude_execution", "anthropic_native_execution"]}, "required_dispatch_capability": {"enum": [null, "native_dispatch", "openrouter_exec"]}}}},
        {"if": {"required": ["required_capability"], "properties": {"required_capability": {"const": "anthropic_native_execution"}}}, "then": {"properties": {"executor": {"const": "claude"}, "required_dispatch_capability": {"const": "native_dispatch"}}}}
      ]
    },
    "safety_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "gate_kind", "required_evidence", "executor", "required_capability", "required_dispatch_capability", "executor_overridable", "required_ancestors"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "gate_kind": {"type": ["string", "null"], "enum": [null, "cleanup", "deterministic_validation", "evidence", "human_approval", "investigation_promotion", "next_action", "risk"]},
        "required_evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "executor": {"type": ["string", "null"], "enum": [null, "claude", "codex", "openrouter"]},
        "required_capability": {"type": ["string", "null"], "enum": [null, "claude_execution", "codex_execution", "openrouter_execution", "anthropic_native_execution"]},
        "required_dispatch_capability": {"type": ["string", "null"], "enum": [null, "native_dispatch", "companion_dispatch", "wrapper_dispatch", "openrouter_exec"]},
        "executor_overridable": {"type": "boolean"},
        "required_ancestors": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {"$ref": "#/$defs/executor_constraint"},
        {"if": {"required": ["executor"], "properties": {"executor": {"const": null}}}, "then": {"properties": {"executor_overridable": {"const": false}}}},
        {"if": {"required": ["gate_kind"], "properties": {"gate_kind": {"enum": ["deterministic_validation", "evidence", "human_approval", "investigation_promotion", "next_action", "risk"]}}}, "then": {"properties": {"required_evidence": {"minItems": 1}}}}
      ]
    },
    "stage_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "stages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/safety_stage"}}
      }
    },
    "workflow_safety_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "common", "classes", "promotion", "non_executable_classes"],
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "common": {"$ref": "#/$defs/stage_set"},
        "classes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hotfix", "security", "migration"],
          "properties": {
            "hotfix": {"$ref": "#/$defs/stage_set"},
            "security": {"$ref": "#/$defs/stage_set"},
            "migration": {"$ref": "#/$defs/stage_set"}
          }
        },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["investigation"],
          "properties": {"investigation": {"$ref": "#/$defs/stage_set"}}
        },
        "non_executable_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": {"const": "investigation"}
        }
      }
    }
  }
}
