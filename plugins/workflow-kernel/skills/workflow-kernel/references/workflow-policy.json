{
  "schema_version": 1,
  "retry": {
    "budgets": {
      "provider_unavailable": 2,
      "deterministic_validation_failure": 1,
      "reviewer_finding": 3,
      "browser_recovery": 1,
      "cleanup": 2,
      "infrastructure": 1
    },
    "identical_signature_limit": 2
