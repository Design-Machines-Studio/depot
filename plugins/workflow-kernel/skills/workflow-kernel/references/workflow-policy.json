    "forbidden_downgrades": [
      {"from": "remote_sandbox", "to": "sequential_branch"}
    ]
  },
  "capability_names": [
    "native_dispatch",
    "companion_dispatch",
    "wrapper_dispatch",
    "session_resume",
    "remote_sandbox",
    "container",
    "worktree",
    "sequential_branch",
    "claude_execution",
    "codex_execution",
    "openrouter_execution",
    "anthropic_native_execution"
  ],
  "economics": {"mode": "proposal_only"}
}
