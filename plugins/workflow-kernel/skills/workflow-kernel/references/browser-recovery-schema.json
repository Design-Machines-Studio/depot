{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/browser-recovery-schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "reason_code", "case_id", "requested_engine",
    "actual_engine", "substitution_provenance", "attempts", "lifecycle",
    "missing_case_ids", "verification_profile_id", "configured_engines",
    "target_url_digest", "target_origin_digest", "target_route_digest", "viewport", "declared_route_digest"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "status": {"enum": ["clean", "recovered", "blocked"]},
    "reason_code": {"enum": ["browser_verified_first_pass", "primary_recovered_degraded", "alternate_engine_recovered_degraded", "human_help_required", "application_failure"]},
    "case_id": {"$ref": "#/$defs/case_id"},
    "requested_engine": {"$ref": "#/$defs/engine"},
    "actual_engine": {"$ref": "#/$defs/engine"},
    "substitution_provenance": {"type": ["string", "null"], "enum": [null, "alternate_engine_recovery"]},
    "attempts": {
      "type": "array", "minItems": 1, "maxItems": 3,
      "prefixItems": [
        {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"attempt_number": {"const": 1}}}]},
        {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"attempt_number": {"const": 2}}}]},
        {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"attempt_number": {"const": 3}}}]}
      ],
      "items": {"$ref": "#/$defs/attempt"}
    },
    "lifecycle": {"type": "array", "items": {"$ref": "#/$defs/lifecycle"}},
    "missing_case_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/case_id"}},
    "verification_profile_id": {"$ref": "#/$defs/profile_id"},
    "configured_engines": {"type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/engine"}},
    "target_url_digest": {"type": "string", "pattern": "^url-sha256:[0-9a-f]{64}$"},
    "target_origin_digest": {"type": "string", "pattern": "^origin-sha256:[0-9a-f]{64}$"},
    "target_route_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "viewport": {"$ref": "#/$defs/viewport"}
    ,"declared_route_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "clean"}}}, "then": {"properties": {"reason_code": {"const": "browser_verified_first_pass"}, "substitution_provenance": {"const": null}, "attempts": {"minItems": 1, "maxItems": 1, "items": {"properties": {"attempt_number": {"const": 1}, "result": {"const": "passed"}, "substitution_provenance": {"const": null}}}}, "lifecycle": {"maxItems": 0}, "missing_case_ids": {"maxItems": 0}}}},
    {"if": {"properties": {"status": {"const": "blocked"}}}, "then": {"properties": {"reason_code": {"enum": ["human_help_required", "application_failure"]}, "substitution_provenance": {"const": null}, "attempts": {"prefixItems": [{"properties": {"result": {"enum": ["failed", "unavailable"]}}}, {"properties": {"result": {"enum": ["failed", "unavailable"]}}}, {"properties": {"result": {"enum": ["failed", "unavailable"]}}}]}, "missing_case_ids": {"minItems": 1, "maxItems": 1}}}},
    {"if": {"properties": {"status": {"const": "recovered"}}}, "then": {"properties": {"reason_code": {"enum": ["primary_recovered_degraded", "alternate_engine_recovered_degraded"]}, "attempts": {"minItems": 2, "prefixItems": [{"properties": {"result": {"enum": ["failed", "unavailable"]}}}]}, "missing_case_ids": {"maxItems": 0}}}},
    {"if": {"properties": {"reason_code": {"const": "primary_recovered_degraded"}}}, "then": {"properties": {"status": {"const": "recovered"}, "substitution_provenance": {"const": null}, "attempts": {"minItems": 2, "maxItems": 2, "prefixItems": [{"properties": {"result": {"enum": ["failed", "unavailable"]}, "substitution_provenance": {"const": null}}}, {"properties": {"result": {"const": "passed"}, "substitution_provenance": {"const": null}}}]}}}},
    {"if": {"properties": {"reason_code": {"const": "alternate_engine_recovered_degraded"}}}, "then": {
      "properties": {"status": {"const": "recovered"}, "substitution_provenance": {"const": "alternate_engine_recovery"}},
      "oneOf": [
        {"properties": {
          "attempts": {"minItems": 2, "maxItems": 2, "prefixItems": [
            {"properties": {"result": {"enum": ["failed", "unavailable"]}, "substitution_provenance": {"const": null}}},
            {"properties": {"result": {"const": "passed"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}}
          ]},
          "lifecycle": {"oneOf": [
            {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]},
            {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{}, {}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]}
          ]}
        }},
        {"properties": {
          "attempts": {"minItems": 3, "maxItems": 3, "prefixItems": [
            {"properties": {"result": {"enum": ["failed", "unavailable"]}, "substitution_provenance": {"const": null}}},
            {"properties": {"result": {"enum": ["failed", "unavailable"]}, "substitution_provenance": {"const": null}}},
            {"properties": {"result": {"const": "passed"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}}
          ]},
          "lifecycle": {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]}
        }}
      ]
    }},
    {"if": {"properties": {"reason_code": {"const": "alternate_engine_recovered_degraded"}}}, "then": {"oneOf": [
      {"allOf": [{"$ref": "#/$defs/chromium_firefox_pair"}, {"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}]}}}]},
      {"allOf": [{"$ref": "#/$defs/chromium_webkit_pair"}, {"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}]}}}]},
      {"allOf": [{"$ref": "#/$defs/firefox_chromium_pair"}, {"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}]}}}]},
      {"allOf": [{"$ref": "#/$defs/firefox_webkit_pair"}, {"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}]}}}]},
      {"allOf": [{"$ref": "#/$defs/webkit_chromium_pair"}, {"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}]}}}]},
      {"allOf": [{"$ref": "#/$defs/webkit_firefox_pair"}, {"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}]}}}]}
    ]}},
    {"if": {"properties": {"reason_code": {"const": "browser_verified_first_pass"}}}, "then": {"properties": {"status": {"const": "clean"}}}},
    {"if": {"properties": {"reason_code": {"const": "human_help_required"}}}, "then": {"properties": {"status": {"const": "blocked"}}}},
    {"if": {"required": ["reason_code", "configured_engines"], "properties": {"reason_code": {"const": "human_help_required"}, "configured_engines": {"minItems": 2}}}, "then": {"oneOf": [
      {"properties": {
        "attempts": {"minItems": 1, "maxItems": 1},
        "lifecycle": {"oneOf": [
          {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{}, {}, {}, {"oneOf": [{"properties": {"action": {"const": "browser_process_launch"}, "result": {"enum": ["unavailable", "fresh_profile_unavailable"]}}}, {"properties": {"action": {"const": "session_validation"}, "result": {"const": "session_identity_mismatch"}}}]}]}]},
          {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{}, {}, {}, {}, {"oneOf": [{"properties": {"action": {"const": "browser_process_launch"}, "result": {"enum": ["unavailable", "fresh_profile_unavailable"]}}}, {"properties": {"action": {"const": "session_validation"}, "result": {"const": "session_identity_mismatch"}}}]}]}]}
        ]}
      }},
      {"properties": {
        "attempts": {"minItems": 2, "maxItems": 2},
        "lifecycle": {"oneOf": [
          {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]},
          {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{}, {}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]},
          {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{}, {}, {}, {"oneOf": [{"properties": {"action": {"const": "browser_process_launch"}, "result": {"enum": ["unavailable", "fresh_profile_unavailable"]}}}, {"properties": {"action": {"const": "session_validation"}, "result": {"const": "session_identity_mismatch"}}}]}]}]}
        ]}
      }},
      {"properties": {
        "attempts": {"minItems": 3, "maxItems": 3},
        "lifecycle": {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{}, {}, {}, {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}]}]}
      }}
    ]}},
    {"if": {"required": ["reason_code", "configured_engines"], "properties": {"reason_code": {"const": "human_help_required"}, "configured_engines": {"minItems": 2}}}, "then": {"oneOf": [
      {"allOf": [{"$ref": "#/$defs/chromium_firefox_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}]}}}]}]},
      {"allOf": [{"$ref": "#/$defs/chromium_webkit_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}]}}}]}]},
      {"allOf": [{"$ref": "#/$defs/firefox_chromium_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}]}}}]}]},
      {"allOf": [{"$ref": "#/$defs/firefox_webkit_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}]}}}]}]},
      {"allOf": [{"$ref": "#/$defs/webkit_chromium_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "chromium"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}]}}}]}]},
      {"allOf": [{"$ref": "#/$defs/webkit_firefox_pair"}, {"oneOf": [{"properties": {"actual_engine": {"const": "webkit"}, "attempts": {"oneOf": [{"minItems": 1, "maxItems": 1, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}]}, {"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}]}]}}}, {"properties": {"actual_engine": {"const": "firefox"}, "attempts": {"oneOf": [{"minItems": 2, "maxItems": 2, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}, {"minItems": 3, "maxItems": 3, "prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}]}}}]}]}
    ]}},
    {"if": {"properties": {"reason_code": {"const": "application_failure"}}}, "then": {"properties": {"status": {"const": "blocked"}}}},
    {"if": {"properties": {"requested_engine": {"const": "chromium"}, "reason_code": {"enum": ["browser_verified_first_pass", "primary_recovered_degraded"]}}}, "then": {"properties": {"actual_engine": {"const": "chromium"}}}},
    {"if": {"properties": {"requested_engine": {"const": "firefox"}, "reason_code": {"enum": ["browser_verified_first_pass", "primary_recovered_degraded"]}}}, "then": {"properties": {"actual_engine": {"const": "firefox"}}}},
    {"if": {"properties": {"requested_engine": {"const": "webkit"}, "reason_code": {"enum": ["browser_verified_first_pass", "primary_recovered_degraded"]}}}, "then": {"properties": {"actual_engine": {"const": "webkit"}}}},
    {"if": {"required": ["status", "configured_engines"], "properties": {"status": {"const": "blocked"}, "configured_engines": {"maxItems": 1}}}, "then": {"properties": {"reason_code": {"const": "human_help_required"}, "lifecycle": {"contains": {"properties": {"action": {"const": "secondary_engine"}, "result": {"const": "secondary_engine_unavailable"}}, "required": ["action", "result"]}}}}}
  ],
  "$defs": {
    "restart_unavailable_lifecycle": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "prefixItems": [
        {"oneOf": [
          {"properties": {"action": {"const": "browser_process_quit"}, "result": {"enum": ["unconfirmed", "unavailable"]}}},
          {"properties": {"action": {"const": "application_restart"}, "result": {"enum": ["confirmed", "unconfirmed"]}}}
        ]},
        {"properties": {"action": {"const": "primary_restart"}, "result": {"const": "primary_restart_unavailable"}}},
        {"properties": {"action": {"const": "readiness_recheck"}}},
        {}
      ]
    },
    "failed_primary_launch_lifecycle": {
      "type": "array", "minItems": 5, "maxItems": 5,
      "prefixItems": [
        {"properties": {"action": {"const": "browser_process_quit"}, "result": {"const": "confirmed"}}},
        {"oneOf": [
          {"properties": {"action": {"const": "browser_process_launch"}, "result": {"enum": ["unavailable", "fresh_profile_unavailable"]}}},
          {"properties": {"action": {"const": "session_validation"}, "result": {"const": "session_identity_mismatch"}}}
        ]},
        {"properties": {"action": {"const": "primary_restart"}, "result": {"const": "primary_restart_unavailable"}}},
        {"properties": {"action": {"const": "readiness_recheck"}}},
        {}
      ]
    },
    "restart_proved_lifecycle": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "prefixItems": [
        {"properties": {"action": {"const": "browser_process_quit"}, "result": {"const": "confirmed"}}},
        {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}},
        {"properties": {"action": {"const": "readiness_recheck"}}},
        {}
      ]
    },
    "chromium_primary_evidence": {"properties": {"requested_engine": {"const": "chromium"}, "actual_engine": {"const": "chromium"}, "substitution_provenance": {"const": null}}},
    "firefox_primary_evidence": {"properties": {"requested_engine": {"const": "firefox"}, "actual_engine": {"const": "firefox"}, "substitution_provenance": {"const": null}}},
    "webkit_primary_evidence": {"properties": {"requested_engine": {"const": "webkit"}, "actual_engine": {"const": "webkit"}, "substitution_provenance": {"const": null}}},
    "chromium_firefox_alternate_evidence": {"properties": {"requested_engine": {"const": "chromium"}, "actual_engine": {"const": "firefox"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "chromium_webkit_alternate_evidence": {"properties": {"requested_engine": {"const": "chromium"}, "actual_engine": {"const": "webkit"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "firefox_chromium_alternate_evidence": {"properties": {"requested_engine": {"const": "firefox"}, "actual_engine": {"const": "chromium"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "firefox_webkit_alternate_evidence": {"properties": {"requested_engine": {"const": "firefox"}, "actual_engine": {"const": "webkit"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "webkit_chromium_alternate_evidence": {"properties": {"requested_engine": {"const": "webkit"}, "actual_engine": {"const": "chromium"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "webkit_firefox_alternate_evidence": {"properties": {"requested_engine": {"const": "webkit"}, "actual_engine": {"const": "firefox"}, "substitution_provenance": {"const": "alternate_engine_recovery"}}},
    "chromium_firefox_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "chromium"},
      "configured_engines": {"allOf": [{"contains": {"const": "chromium"}}, {"contains": {"const": "firefox"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_firefox_alternate_evidence"}]}]}
      ]}
    }},
    "chromium_webkit_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "chromium"},
      "configured_engines": {"allOf": [{"contains": {"const": "chromium"}}, {"contains": {"const": "webkit"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_primary_evidence"}, {"$ref": "#/$defs/chromium_webkit_alternate_evidence"}]}]}
      ]}
    }},
    "firefox_chromium_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "firefox"},
      "configured_engines": {"allOf": [{"contains": {"const": "firefox"}}, {"contains": {"const": "chromium"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_chromium_alternate_evidence"}]}]}
      ]}
    }},
    "firefox_webkit_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "firefox"},
      "configured_engines": {"allOf": [{"contains": {"const": "firefox"}}, {"contains": {"const": "webkit"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_primary_evidence"}, {"$ref": "#/$defs/firefox_webkit_alternate_evidence"}]}]}
      ]}
    }},
    "webkit_chromium_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "webkit"},
      "configured_engines": {"allOf": [{"contains": {"const": "webkit"}}, {"contains": {"const": "chromium"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_chromium_alternate_evidence"}]}]}
      ]}
    }},
    "webkit_firefox_pair": {"required": ["requested_engine", "configured_engines", "lifecycle"], "properties": {
      "requested_engine": {"const": "webkit"},
      "configured_engines": {"allOf": [{"contains": {"const": "webkit"}}, {"contains": {"const": "firefox"}}]},
      "lifecycle": {"oneOf": [
        {"allOf": [{"$ref": "#/$defs/restart_unavailable_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/failed_primary_launch_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}]},
        {"allOf": [{"$ref": "#/$defs/restart_proved_lifecycle"}, {"prefixItems": [{"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_primary_evidence"}, {"$ref": "#/$defs/webkit_firefox_alternate_evidence"}]}]}
      ]}
    }},
    "case_id": {"type": "string", "minLength": 1, "pattern": "^[^\\s/?#@]{1,128}$"},
    "engine": {"enum": ["chromium", "firefox", "webkit"]},
    "profile_id": {"type": "string", "pattern": "^profile-sha256:[0-9a-f]{64}$"},
    "viewport": {"type": "string", "pattern": "^(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])x(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])$"},
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "safe_reference": {
      "type": ["string", "null"],
      "pattern": "^(?:(?:[A-Za-z0-9_][A-Za-z0-9._-]*/)*[A-Za-z0-9_][A-Za-z0-9._-]*|(?:sha256|url-sha256):[0-9a-f]{64})$"
    },
    "reason_code": {
      "type": ["string", "null"],
      "enum": [
        null, "adapter_exception", "invalid_adapter_evidence", "browser_tool_failure",
        "browser_unavailable", "curl_not_browser_evidence", "session_identity_mismatch",
        "fresh_profile_unavailable", "secondary_engine_unavailable", "application_failure",
        "dev_server_unavailable", "target_url_unavailable", "auth_fixture_unavailable",
        "readiness_recheck_unavailable"
      ]
    },
    "failure_detail": {
      "type": ["string", "null"],
      "pattern": "^(?:value-sha256|sha256|url-sha256):[0-9a-f]{64}$"
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id", "attempt_number", "requested_engine", "actual_engine", "action",
        "result", "reason_code", "failure_detail", "screenshot_reference",
        "trace_reference", "console_reference", "session_id", "proof_kind",
        "substitution_provenance", "verification_profile_id", "configured_engines",
        "target_url_digest", "target_origin_digest", "target_route_digest", "viewport", "declared_route_digest"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/case_id"},
        "attempt_number": {"type": "integer", "minimum": 1},
        "requested_engine": {"$ref": "#/$defs/engine"},
        "actual_engine": {"$ref": "#/$defs/engine"},
        "action": {"const": "verify"},
        "result": {"enum": ["passed", "failed", "unavailable"]},
        "reason_code": {"$ref": "#/$defs/reason_code"},
        "failure_detail": {"$ref": "#/$defs/failure_detail"},
        "screenshot_reference": {"$ref": "#/$defs/safe_reference"},
        "trace_reference": {"$ref": "#/$defs/safe_reference"},
        "console_reference": {"$ref": "#/$defs/safe_reference"},
        "session_id": {"$ref": "#/$defs/session_id"},
        "proof_kind": {"enum": ["browser", "curl", "reachability"]},
        "substitution_provenance": {"type": ["string", "null"], "enum": [null, "alternate_engine_recovery"]},
        "verification_profile_id": {"$ref": "#/$defs/profile_id"},
        "configured_engines": {"type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/engine"}},
        "target_url_digest": {"type": "string", "pattern": "^url-sha256:[0-9a-f]{64}$"},
        "target_origin_digest": {"type": "string", "pattern": "^origin-sha256:[0-9a-f]{64}$"},
        "target_route_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "viewport": {"$ref": "#/$defs/viewport"},
        "declared_route_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "allOf": [
        {"if": {"properties": {"result": {"const": "passed"}}}, "then": {"properties": {"reason_code": {"const": null}, "failure_detail": {"const": null}, "proof_kind": {"const": "browser"}}}},
        {"if": {"properties": {"result": {"enum": ["failed", "unavailable"]}}}, "then": {"properties": {"reason_code": {"enum": ["adapter_exception", "invalid_adapter_evidence", "browser_tool_failure", "browser_unavailable", "curl_not_browser_evidence", "session_identity_mismatch", "application_failure"]}}}},
        {"if": {"properties": {"substitution_provenance": {"const": null}}}, "then": {"allOf": [
          {"if": {"properties": {"requested_engine": {"const": "chromium"}}}, "then": {"properties": {"actual_engine": {"const": "chromium"}}}},
          {"if": {"properties": {"requested_engine": {"const": "firefox"}}}, "then": {"properties": {"actual_engine": {"const": "firefox"}}}},
          {"if": {"properties": {"requested_engine": {"const": "webkit"}}}, "then": {"properties": {"actual_engine": {"const": "webkit"}}}}
        ]}}
      ]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id", "requested_engine", "actual_engine", "action", "result",
        "session_id", "previous_session_id", "reason_code", "failure_detail",
        "substitution_provenance", "fresh_profile", "readiness_checks", "readiness_evidence_digest"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/case_id"},
        "requested_engine": {"$ref": "#/$defs/engine"},
        "actual_engine": {"$ref": "#/$defs/engine"},
        "action": {"enum": ["browser_process_quit", "browser_process_launch", "application_restart", "primary_restart", "session_validation", "secondary_engine", "readiness_recheck"]},
        "result": {"enum": ["confirmed", "unconfirmed", "launched", "unavailable", "primary_restart_unavailable", "session_identity_mismatch", "fresh_profile_unavailable", "secondary_engine_unavailable"]},
        "session_id": {"$ref": "#/$defs/session_id"},
        "previous_session_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
        "reason_code": {"$ref": "#/$defs/reason_code"},
        "failure_detail": {"$ref": "#/$defs/failure_detail"},
        "substitution_provenance": {"type": ["string", "null"], "enum": [null, "alternate_engine_recovery"]},
        "fresh_profile": {"type": ["boolean", "null"]},
        "readiness_checks": {"type": ["array", "null"], "minItems": 3, "maxItems": 3, "items": {"enum": ["confirmed", "unavailable"]}},
        "readiness_evidence_digest": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "allOf": [
        {"if": {"properties": {"action": {"const": "browser_process_quit"}}}, "then": {"properties": {"result": {"enum": ["confirmed", "unconfirmed", "unavailable"]}}}},
        {"if": {"properties": {"action": {"const": "application_restart"}}}, "then": {"properties": {"result": {"enum": ["confirmed", "unconfirmed"]}}}},
        {"if": {"properties": {"action": {"const": "browser_process_launch"}}}, "then": {"properties": {"result": {"enum": ["launched", "unavailable", "fresh_profile_unavailable"]}}}},
        {"if": {"properties": {"action": {"const": "primary_restart"}}}, "then": {"properties": {"result": {"const": "primary_restart_unavailable"}}}},
        {"if": {"properties": {"action": {"const": "session_validation"}}}, "then": {"properties": {"result": {"const": "session_identity_mismatch"}}}},
        {"if": {"properties": {"action": {"const": "secondary_engine"}}}, "then": {"properties": {"result": {"const": "secondary_engine_unavailable"}}}},
        {"if": {"properties": {"action": {"const": "readiness_recheck"}}}, "then": {"properties": {"result": {"enum": ["confirmed", "unavailable"]}, "fresh_profile": {"const": null}, "readiness_checks": {"type": "array", "minItems": 3, "maxItems": 3}, "readiness_evidence_digest": {"type": "string"}}}},
        {"if": {"properties": {"result": {"const": "session_identity_mismatch"}}}, "then": {"properties": {"reason_code": {"const": "session_identity_mismatch"}}}},
        {"if": {"properties": {"result": {"const": "fresh_profile_unavailable"}}}, "then": {"properties": {"reason_code": {"const": "fresh_profile_unavailable"}}}},
        {"if": {"properties": {"result": {"const": "secondary_engine_unavailable"}}}, "then": {"properties": {"reason_code": {"const": "secondary_engine_unavailable"}}}},
        {"if": {"properties": {"result": {"const": "unconfirmed"}}}, "then": {"properties": {"reason_code": {"const": "browser_unavailable"}}}},
        {"if": {"properties": {"result": {"const": "primary_restart_unavailable"}}}, "then": {"properties": {"reason_code": {"const": null}}}},
        {"if": {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "launched"}}}, "then": {"properties": {"fresh_profile": {"const": true}}}},
        {"if": {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "fresh_profile_unavailable"}}}, "then": {"properties": {"fresh_profile": {"const": false}}}},
        {"if": {"properties": {"action": {"const": "browser_process_launch"}, "result": {"const": "unavailable"}}}, "then": {"properties": {"fresh_profile": {"const": null}}}},
        {"if": {"properties": {"action": {"enum": ["browser_process_quit", "application_restart", "primary_restart", "session_validation", "secondary_engine", "readiness_recheck"]}}}, "then": {"properties": {"fresh_profile": {"const": null}}}},
        {"if": {"properties": {"action": {"enum": ["browser_process_quit", "browser_process_launch", "application_restart", "primary_restart", "session_validation", "secondary_engine"]}}}, "then": {"properties": {"readiness_checks": {"const": null}, "readiness_evidence_digest": {"const": null}}}},
        {"if": {"properties": {"result": {"enum": ["confirmed", "launched"]}}}, "then": {"properties": {"reason_code": {"const": null}, "failure_detail": {"const": null}}}},
        {"if": {"properties": {"action": {"const": "readiness_recheck"}, "result": {"const": "unavailable"}}}, "then": {"properties": {"reason_code": {"enum": ["adapter_exception", "invalid_adapter_evidence", "dev_server_unavailable", "target_url_unavailable", "auth_fixture_unavailable", "readiness_recheck_unavailable"]}}}},
        {"if": {"properties": {"action": {"enum": ["browser_process_quit", "browser_process_launch"]}, "result": {"const": "unavailable"}}}, "then": {"properties": {"reason_code": {"enum": ["adapter_exception", "invalid_adapter_evidence", "browser_tool_failure", "browser_unavailable", "curl_not_browser_evidence", "session_identity_mismatch"]}}}}
      ]
    }
  }
}
