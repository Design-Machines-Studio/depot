{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/verification-profile-schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "source", "discovery_status", "selection_status", "configured_engines", "target_origin_digest", "cases", "auth_field_names", "coverage_diagnostics"],
  "properties": {
    "schema_version": {"const": 1},
    "profile_id": {"type": "string", "pattern": "^profile-sha256:[0-9a-f]{64}$"},
    "source": {"enum": ["project_declaration", "not_declared"]},
    "discovery_status": {"enum": ["declared", "not_declared"]},
    "selection_status": {"enum": ["runnable_cases", "optional_cases_only", "no_runnable_tasks", "not_declared"]},
    "auth_field_names": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}},
    "coverage_diagnostics": {"type": "array", "uniqueItems": true, "items": {"enum": ["coverage_matrix_mismatch"]}},
    "configured_engines": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/engine"}},
    "target_origin_digest": {"type": ["string", "null"], "pattern": "^origin-sha256:[0-9a-f]{64}$"},
    "cases": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/case"}}
  },
  "allOf": [
    {"if": {"properties": {"discovery_status": {"const": "not_declared"}}}, "then": {"properties": {"source": {"const": "not_declared"}, "selection_status": {"const": "not_declared"}, "configured_engines": {"maxItems": 0}, "cases": {"maxItems": 0}}}},
    {"if": {"properties": {"source": {"const": "not_declared"}}}, "then": {"properties": {"discovery_status": {"const": "not_declared"}}}},
    {"if": {"properties": {"discovery_status": {"const": "declared"}}}, "then": {"properties": {"source": {"const": "project_declaration"}, "selection_status": {"enum": ["runnable_cases", "optional_cases_only", "no_runnable_tasks"]}, "configured_engines": {"minItems": 1}}}},
    {"if": {"properties": {"source": {"const": "project_declaration"}}}, "then": {"properties": {"discovery_status": {"const": "declared"}}}},
    {"if": {"properties": {"selection_status": {"const": "not_declared"}}}, "then": {"properties": {"source": {"const": "not_declared"}, "discovery_status": {"const": "not_declared"}, "configured_engines": {"maxItems": 0}, "cases": {"maxItems": 0}}}},
    {"if": {"properties": {"selection_status": {"const": "no_runnable_tasks"}}}, "then": {"properties": {"source": {"const": "project_declaration"}, "discovery_status": {"const": "declared"}, "cases": {"maxItems": 0}}}},
    {"if": {"properties": {"selection_status": {"const": "optional_cases_only"}}}, "then": {"properties": {"cases": {"minItems": 1, "items": {"allOf": [{"$ref": "#/$defs/case"}, {"properties": {"required": {"const": false}}}]}}}}},
    {"if": {"properties": {"selection_status": {"const": "runnable_cases"}}}, "then": {"properties": {"cases": {"minItems": 1, "contains": {"properties": {"required": {"const": true}}, "required": ["required"]}}}}}
  ],
  "$defs": {
    "identifier": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "role_identifier": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^(?!(?:.*[._-])?(?:token|key|secret|password|authorization|cookie|dsn)(?:[._-].*)?$)[a-z0-9][a-z0-9._-]*$"},
    "engine": {"enum": ["chromium", "firefox", "webkit"]},
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "persona_id", "scenario_id", "role", "route", "browser_engine", "viewport", "required", "expected_outcome", "requires_auth", "browser_source", "viewport_source", "legacy_status_defaulted"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^case-sha256:[0-9a-f]{64}$"},
        "persona_id": {"$ref": "#/$defs/identifier"},
        "scenario_id": {"$ref": "#/$defs/identifier"},
        "role": {"$ref": "#/$defs/role_identifier"},
        "route": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^/(?!/)(?!(?:sk-|gh[pousr]_|xox[baprs]-|bearer(?:%20|\\s)))(?!.*\\/(?:sk-|gh[pousr]_|xox[baprs]-|bearer(?:%20|\\s)))(?!(?:\\.|%2[eE]){1,2}(?:/|$))(?!.*\\/(?:\\.|%2[eE]){1,2}(?:/|$))[^?#\\\\]*$"},
        "browser_engine": {"$ref": "#/$defs/engine"},
        "viewport": {"type": "string", "pattern": "^(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])x(?:[1-9][0-9]{1,3}|1[0-5][0-9]{3}|16[0-2][0-9]{2}|163[0-7][0-9]|1638[0-4])$"},
        "required": {"type": "boolean"},
        "expected_outcome": {"enum": ["SUCCESS", "FRICTION", "BLOCKED", "PARTIAL"]},
        "requires_auth": {"type": "boolean"},
        "browser_source": {"enum": ["project_config", "workflow_policy_default"]},
        "viewport_source": {"enum": ["project_config", "task_declaration", "persona_default", "workflow_policy_default"]},
        "legacy_status_defaulted": {"type": "boolean"}
      }
    }
  }
}
