{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/workflow-kernel/cleanup-receipt-v1.json",
  "title": "Workflow kernel cleanup receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "before", "after", "dispositions"],
  "properties": {
    "schema_version": {"const": 1},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "terminal", "stale_sweep"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "node_id": {"type": "string", "minLength": 1},
        "terminal": {"type": "boolean"},
        "stale_sweep": {"type": "boolean"}
      }
    },
    "before": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "after": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "dispositions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_id", "kind", "owner", "lifecycle", "disposition", "action", "reason", "evidence"],
        "properties": {
          "resource_id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["worktree", "branch", "container", "network", "volume"]},
          "owner": {
            "type": "object",
            "additionalProperties": false,
            "required": ["run_id", "node_id"],
            "properties": {
              "run_id": {"type": "string", "minLength": 1},
              "node_id": {"type": "string", "minLength": 1}
            }
          },
          "lifecycle": {"enum": ["chunk", "run"]},
          "disposition": {"enum": ["removed", "retained_for_dependency", "blocked", "foreign", "missing"]},
          "action": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "follow_up": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
