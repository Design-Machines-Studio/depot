{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designmachines.ca/schemas/workflow-classes-schema.json",
  "title": "Workflow Kernel Class Templates",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "classes", "promotion"],
  "properties": {
    "schema_version": {"const": 1},
    "classes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chore", "bug", "feature", "hotfix", "security", "investigation", "migration"],
      "properties": {
        "chore": {"$ref": "#/$defs/workflow"},
        "bug": {"$ref": "#/$defs/workflow"},
        "feature": {"$ref": "#/$defs/workflow"},
        "hotfix": {"$ref": "#/$defs/workflow"},
        "security": {"$ref": "#/$defs/workflow"},
        "investigation": {"$ref": "#/$defs/workflow"},
        "migration": {"$ref": "#/$defs/workflow"}
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["investigation"],
      "properties": {"investigation": {"$ref": "#/$defs/workflow"}}
    }
  },
  "$defs": {
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node"}}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "depends_on", "gate_kind", "required_evidence", "executor", "required_capability", "executor_overridable"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "depends_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "gate_kind": {"type": ["string", "null"], "enum": [null, "cleanup", "deterministic_validation", "evidence", "human_approval", "investigation_promotion", "next_action", "risk"]},
        "required_evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "executor": {"type": ["string", "null"], "enum": [null, "claude", "codex", "openrouter"]},
        "required_capability": {"type": ["string", "null"], "enum": [null, "claude_execution", "codex_execution", "openrouter_execution"]},
        "executor_overridable": {"type": "boolean"}
      }
    }
  }
}
