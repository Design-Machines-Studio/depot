.claude/settings.local.json
.env
*.local

# Pipeline-generated feature artefacts (per-feature plans, briefs, manifests, prompts)
plans/
plans/*/baselines/
plans/*/baselines-pre-fix/
plans/*/baselines-post-fix/
plans/*/screenshots/
plans/*/prompts/
plans/*/manifest.json
plans/*/brainstorm.md
.workflow-kernel/
.worktrees/
.claude/ux-review/
todos/
.playwright-mcp/
plans/*/brainstorm.html

# Airlift handoff bundles are local by default. uncommitted.patch captures the
# working tree verbatim and can contain secrets (.env values, tokens) -- review
# it before force-adding, committing, or sharing any receipt that should travel.
.airlift/

# Python bytecode (workflow-kernel reference runtime test runs)
__pycache__/
*.pyc
